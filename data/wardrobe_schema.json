{
  "description": "Schema for a user's existing wardrobe. A wardrobe is an object with an 'items' list. Each item describes one piece the user already owns, so suggest_outfit can pair a new listing against real pieces.",
  "item_fields": {
    "id": "string — unique id for the wardrobe item",
    "type": "string — garment type, e.g. 'jeans', 'sneakers', 'jacket', 'tee'",
    "descriptor": "string — short natural-language description used in styling prompts, e.g. 'baggy wide-leg jeans'",
    "colors": "array of strings — dominant colors",
    "style_tags": "array of strings — style descriptors, e.g. ['90s', 'streetwear']",
    "fit": "string — fit/silhouette, e.g. 'baggy', 'fitted', 'oversized'"
  },
  "example_wardrobe": {
    "items": [
      {
        "id": "W1",
        "type": "jeans",
        "descriptor": "baggy wide-leg jeans",
        "colors": ["blue"],
        "style_tags": ["90s", "streetwear", "casual"],
        "fit": "baggy"
      },
      {
        "id": "W2",
        "type": "sneakers",
        "descriptor": "chunky platform sneakers",
        "colors": ["white"],
        "style_tags": ["y2k", "chunky"],
        "fit": "chunky"
      },
      {
        "id": "W3",
        "type": "jacket",
        "descriptor": "oversized denim trucker jacket",
        "colors": ["blue"],
        "style_tags": ["vintage", "90s"],
        "fit": "oversized"
      },
      {
        "id": "W4",
        "type": "beanie",
        "descriptor": "ribbed black beanie",
        "colors": ["black"],
        "style_tags": ["casual", "streetwear"],
        "fit": "snug"
      }
    ]
  },
  "empty_wardrobe": {
    "items": []
  }
}
